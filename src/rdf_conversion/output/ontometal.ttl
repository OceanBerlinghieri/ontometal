@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix om: <https://w3id.org/ontometal#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:available rdfs:subPropertyOf dcterms:date ;
    owl:equivalentProperty om:releaseYear .

<http://purl.org/ontology/mo/Genre> owl:equivalentClass om:Genre .

<http://purl.org/ontology/mo/Label> owl:equivalentClass om:Label .

<http://purl.org/ontology/mo/MusicGroup> owl:equivalentClass om:Band .

<http://purl.org/ontology/mo/releaseType> rdfs:label "releaseType"@en ;
    rdfs:comment "Defines de type of a release as album, single, compilation.."@en ;
    rdfs:domain om:Release ;
    rdfs:range <http://purl.org/ontology/mo/ReleaseType> .

<https://w3id.org/ontometal> a owl:Ontology ;
    dc:contributor "Ocean Berlinghieri García" ;
    dc:created "2026-04-19" ;
    dc:creator "Ocean Berlinghieri García" ;
    dc:publisher "Ocean Berlinghieri García" ;
    dc:title "ontometal" ;
    dcterms:license "https://creativecommons.org/licenses/by/4.0/" ;
    vann:preferredNamespacePrefix "om" ;
    vann:preferredNamespaceUri "https://w3id.org/ontometal" ;
    rdfs:comment "Ontology about metal music" ;
    owl:imports <http://purl.org/ontology/mo/> ;
    owl:versionIRI <https://w3id.org/ontometal-0.0.1_dev> ;
    owl:versionInfo "0.0.1_dev - First ontology prototype" .

