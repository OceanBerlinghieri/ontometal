    om:genreName "viking black metal"^^xsd:string .

om:VikingFolkMetal a om:Genre ;
    om:genreName "viking folk metal"^^xsd:string .

om:VikingMetal a om:Genre ;
    om:genreName "viking metal"^^xsd:string .

om:VikingMetalWithBlack a om:Genre ;
    om:genreName "viking metal with black"^^xsd:string .

om:VikingMetalWithBlackMetalInfluences a om:Genre ;
    om:genreName "viking metal with black metal influences"^^xsd:string .

om:VikingMetalWithDeathMetalInfluences a om:Genre ;
    om:genreName "viking metal with death metal influences"^^xsd:string .

om:VikingRock a om:Genre ;
    om:genreName "viking rock"^^xsd:string .

om:WitchHouse a om:Genre ;
    om:genreName "witch house"^^xsd:string .

om:WorldFolk a om:Genre ;
    om:genreName "world folk"^^xsd:string .

om:WorldMusic a om:Genre ;
    om:genreName "world music"^^xsd:string .

om:Zimbabwe a om:Country ;
    om:countryName "zimbabwe"^^xsd:string .

om:bandID a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "bandID"@en ;
    rdfs:comment "Identifier by metal archives"@en ;
    rdfs:domain om:Band ;
    rdfs:range xsd:long ;
    rdfs:subPropertyOf dcterms:identifier .

om:bandName a owl:DatatypeProperty ;
    rdfs:label "bandName"@en ;
    rdfs:comment "Name of a given band"@en ;
    rdfs:domain om:Band ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf foaf:name .

om:bandStatus a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "bandStatus" ;
    rdfs:comment "Status of a band (active, split..)" ;
    rdfs:domain om:Band ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf foaf:status .

om:countryName a owl:DatatypeProperty ;
    rdfs:label "countryName"@en ;
    rdfs:comment "Name of a given country"@en ;
    rdfs:domain om:Country ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf foaf:name .

om:genreID a owl:DatatypeProperty ;
    rdfs:label "genreID"@en ;
    rdfs:comment "Identifier of a genre"@en ;
    rdfs:subPropertyOf dcterms:identifier .

om:genreName a owl:DatatypeProperty ;
    rdfs:label "genreName"@en ;
    rdfs:comment "Name of a music genre"@en ;
    rdfs:subPropertyOf foaf:name .

om:hasCountry a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "hasCountry"@en ;
    rdfs:comment "Relates an entity with its origin country"@en ;
    rdfs:domain om:Band,
        om:Label ;
    rdfs:range om:Country ;
    rdfs:subPropertyOf foaf:based_near .

om:hasGenre a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "hasGenre"@en ;
    rdfs:comment "Relates a band with one or more genres"@en ;
    rdfs:domain om:Band ;
    rdfs:range om:Genre ;
    rdfs:subPropertyOf <http://purl.org/ontology/ao/core#genre> .

om:hasSpecialization a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "Relates a label with its preferred musical genre"@en,
        "hasSpecialization"@en ;
    rdfs:domain om:Label ;
    rdfs:range om:Genre ;
    rdfs:subPropertyOf <http://purl.org/ontology/ao/core#genre> .

om:labelID a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "labelID"@en ;
    rdfs:comment "Identifier by metal archives"@en ;
    rdfs:domain om:Label ;
    rdfs:range xsd:long ;
    rdfs:subPropertyOf dcterms:identifier .

om:labelName a owl:DatatypeProperty ;
    rdfs:label "labelName"@en ;
    rdfs:comment "Name of a given label"@en ;
    rdfs:domain om:Label ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf foaf:name .

om:labelStatus a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "labelStatus" ;
    rdfs:comment "Status of a label (closed, active, changedName..)" ;
    rdfs:domain om:Label ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf foaf:status .

om:labelWebsiteURL a owl:DatatypeProperty ;
    rdfs:label "labelWebsiteURL"@en ;
    rdfs:comment "URL of a label website"@en ;
    rdfs:domain om:Label ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf om:url .

om:metalArchivesURL a owl:DatatypeProperty ;
    rdfs:label "metalArchivesURL"@en ;
    rdfs:comment "URL of a band page in metal archives website"@en ;
    rdfs:domain om:Band ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf om:url .

om:producedBy a owl:ObjectProperty ;
    rdfs:label "producedBy" ;
    rdfs:comment "Relates a band which is produces by a label"@en ;
    rdfs:domain om:Band ;
    rdfs:range om:Band,
        om:Label ;
    rdfs:subPropertyOf <http://purl.org/NET/c4dm/event.owl#isAgentIn> ;
    owl:inverseOf om:producer .

om:releaseTitle a owl:DatatypeProperty ;
    rdfs:label "releaseTitle"@en ;
    rdfs:comment "Title of a band release"@en ;
    rdfs:domain om:Release ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dcterms:title .

om:releasedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "releasedBy"@en ;
    rdfs:comment "Relates a release with the band that released it"@en ;
    rdfs:domain om:Release ;
    rdfs:range om:Band ;
    rdfs:subPropertyOf foaf:made ;
    owl:inverseOf om:releases .

om:ÅlandIslands a om:Country ;
    om:countryName "åland islands"^^xsd:string .

om:producer a owl:ObjectProperty ;
    rdfs:label "producer"@en ;
    rdfs:comment "Relates a band or musical composition to its producer (label)"@en ;
    rdfs:domain om:Band,
        om:Label ;
    rdfs:range om:Band ;
    rdfs:subPropertyOf <http://purl.org/NET/c4dm/event.owl#agent> .

om:releaseYear a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "releaseYear"@en ;
    rdfs:comment "Year when a band release came out"@en ;
    rdfs:domain om:Release ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf dcterms:date .

om:releases a owl:ObjectProperty ;
    rdfs:label "releases"@en ;
    rdfs:comment "Relates a band with a release"@en ;
    rdfs:domain om:Band ;
    rdfs:range om:Release ;
    rdfs:subPropertyOf foaf:maker .

om:url a owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:comment "A link to acess a website" .

om:Release a owl:Class ;
    rdfs:label "Release"@en ;
    rdfs:comment "Music release from a band. Equivalent to mo:ReleaseType"@en .

om:Label a owl:Class ;
    rdfs:label "Label"@en ;
    rdfs:comment "Comercial organization from music industry. Equivalent to mo:Label"@en .

om:Band a owl:Class ;
    rdfs:label "Band"@en ;
    rdfs:comment "Class representing a music group. Equivalent to mo:MusicGroup"@en .

om:Country a owl:Class,
        om:Genre ;
    rdfs:label "Country"@en ;
    rdfs:comment "A class representing a country"@en ;
    om:genreName "country"^^xsd:string .

om:Genre a owl:Class ;
    rdfs:label "Genre"@en ;
    rdfs:comment "Music genre class, equivalent to mo:Genre"@en .

