@prefix : <http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/> .
@prefix mo: <https://purl.org/ontology/mo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/> .

<http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal> rdf:type owl:Ontology ;
                                                                owl:versionIRI <http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal-0.0.1_dev> ;
                                                                owl:imports <http://purl.org/ontology/mo/> ;
                                                                <http://purl.org/dc/elements/1.1/contributor> "Ocean Berlinghieri García" ;
                                                                <http://purl.org/dc/elements/1.1/created> "2026-04-19" ;
                                                                <http://purl.org/dc/elements/1.1/creator> "Ocean Berlinghieri García" ;
                                                                <http://purl.org/dc/elements/1.1/publisher> "Ocean Berlinghieri García" ;
                                                                <http://purl.org/dc/elements/1.1/title> "ontometal" ;
                                                                <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/" ;
                                                                <http://purl.org/vocab/vann/preferredNamespacePrefix> "om" ;
                                                                <http://purl.org/vocab/vann/preferredNamespaceUri> "http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal" ;
                                                                rdfs:comment "Ontology about metal music" ;
                                                                owl:versionInfo "0.0.1_dev - First ontology prototype" .

#################################################################
#    Object Properties
#################################################################

###  http://purl.org/ontology/mo/releaseType
<http://purl.org/ontology/mo/releaseType> rdfs:domain :Release ;
                                          rdfs:range <http://purl.org/ontology/mo/ReleaseType> ;
                                          rdfs:comment "Defines de type of a release as album, single, compilation.."@en ;
                                          rdfs:label "releaseType"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasCountry
:hasCountry rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/based_near> ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Band ,
                        :Label ;
            rdfs:range :Country ;
            rdfs:comment "Relates an entity with its origin country"@en ;
            rdfs:label "hasCountry"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasGenre
:hasGenre rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://purl.org/ontology/ao/core#genre> ;
          rdf:type owl:TransitiveProperty ;
          rdfs:domain :Band ;
          rdfs:range :Genre ;
          rdfs:comment "Relates a band with one or more genres"@en ;
          rdfs:label "hasGenre"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasSpecialization
:hasSpecialization rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf <http://purl.org/ontology/ao/core#genre> ;
                   rdf:type owl:TransitiveProperty ;
                   rdfs:domain :Label ;
                   rdfs:range :Genre ;
                   rdfs:label "Relates a label with its preferred musical genre"@en ,
                              "hasSpecialization"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producedBy
:producedBy rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf <http://purl.org/NET/c4dm/event.owl#isAgentIn> ;
            owl:inverseOf :producer ;
            rdfs:domain :Band ;
            rdfs:range :Band ,
                       :Label ;
            rdfs:comment "Relates a band which is produces by a label"@en ;
            rdfs:label "producedBy" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producer
:producer rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://purl.org/NET/c4dm/event.owl#agent> ;
          rdfs:domain :Band ,
                      :Label ;
          rdfs:range :Band ;
          rdfs:comment "Relates a band or musical composition to its producer (label)"@en ;
          rdfs:label "producer"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releasedBy
:releasedBy rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/made> ;
            owl:inverseOf :releases ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Release ;
            rdfs:range :Band ;
            rdfs:comment "Relates a release with the band that released it"@en ;
            rdfs:label "releasedBy"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releases
:releases rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/maker> ;
          rdfs:domain :Band ;
          rdfs:range :Release ;
          rdfs:comment "Relates a band with a release"@en ;
          rdfs:label "releases"@en .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/available
<http://purl.org/dc/terms/available> owl:equivalentProperty :releaseYear ;
                                     rdfs:subPropertyOf <http://purl.org/dc/terms/date> .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandID
:bandID rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
        rdf:type owl:FunctionalProperty ;
        rdfs:domain :Band ;
        rdfs:range xsd:long ;
        rdfs:comment "Identifier by metal archives"@en ;
        rdfs:label "bandID"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandName
:bandName rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
          rdfs:domain :Band ;
          rdfs:range xsd:string ;
          rdfs:comment "Name of a given band"@en ;
          rdfs:label "bandName"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandStatus
:bandStatus rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/status> ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Band ;
            rdfs:range xsd:string .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/countryName
:countryName rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
             rdfs:domain :Country ;
             rdfs:range xsd:string ;
             rdfs:comment "Name of a given country"@en ;
             rdfs:label "countryName"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelID
:labelID rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :Label ;
         rdfs:range xsd:long ;
         rdfs:comment "Identifier by metal archives"@en ;
         rdfs:label "labelID"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelName
:labelName rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
           rdfs:domain :Label ;
           rdfs:range xsd:string ;
           rdfs:comment "Name of a given label"@en ;
           rdfs:label "labelName"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelStatus
:labelStatus rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/status> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :Label ;
             rdfs:range xsd:string .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelWebsiteURL
:labelWebsiteURL rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf :url ;
                 rdfs:domain :Label ;
                 rdfs:range xsd:string ;
                 rdfs:comment "URL of a label website"@en ;
                 rdfs:label "labelWebsiteURL"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/metalArchivesURL
:metalArchivesURL rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :url ;
                  rdfs:domain :Band ;
                  rdfs:range xsd:string ;
                  rdfs:comment "URL of a band page in metal archives website"@en ;
                  rdfs:label "metalArchivesURL"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releaseTitle
:releaseTitle rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf <http://purl.org/dc/terms/title> ;
              rdfs:domain :Release ;
              rdfs:range xsd:string ;
              rdfs:comment "Title of a band release"@en ;
              rdfs:label "releaseTitle"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releaseYear
:releaseYear rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/terms/date> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :Release ;
             rdfs:range xsd:gYear ;
             rdfs:comment "Year when a band release came out"@en ;
             rdfs:label "releaseYear"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/url
:url rdf:type owl:DatatypeProperty ;
     rdfs:comment "A link to acess a website" ;
     rdfs:label "url" .


#################################################################
#    Classes
#################################################################

###  http://purl.org/ontology/mo/Genre
<http://purl.org/ontology/mo/Genre> owl:equivalentClass :Genre .


###  http://purl.org/ontology/mo/Label
<http://purl.org/ontology/mo/Label> owl:equivalentClass :Label .


###  http://purl.org/ontology/mo/MusicGroup
<http://purl.org/ontology/mo/MusicGroup> owl:equivalentClass :Band .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band
:Band rdf:type owl:Class ;
      rdfs:comment "Class representing a music group. Equivalent to mo:MusicGroup"@en ;
      rdfs:label "Band"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Country
:Country rdf:type owl:Class ;
         rdfs:comment "A class representing a country"@en ;
         rdfs:label "Country"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre
:Genre rdf:type owl:Class ;
       rdfs:comment "Music genre class, equivalent to mo:Genre"@en ;
       rdfs:label "Genre"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label
:Label rdf:type owl:Class ;
       rdfs:comment "Comercial organization from music industry. Equivalent to mo:Label"@en ;
       rdfs:label "Label"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/MetalGenre
:MetalGenre rdf:type owl:Class ;
            rdfs:subClassOf :Genre ;
            rdfs:comment "A class representing musical subgenres from metal music"@en ;
            rdfs:label "MetalGenre"@en .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Release
:Release rdf:type owl:Class ;
         rdfs:comment "Music release from a band. Equivalent to mo:ReleaseType"@en ;
         rdfs:label "Release"@en .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/CapitolRecords
:CapitolRecords rdf:type owl:NamedIndividual ,
                         :Label ;
                :hasCountry :USA ;
                :producer :Megadeth ;
                :labelID 1 ;
                :labelName "Capitol Records" ;
                :labelStatus "Active" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/ColumbiaRecords
:ColumbiaRecords rdf:type owl:NamedIndividual ,
                          :Label ;
                 :hasCountry :USA ;
                 :producer :IronMaiden ;
                 :labelID 2 ;
                 :labelName "Columbia Records" ;
                 :labelStatus "Active" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/DanceOfDeath
:DanceOfDeath rdf:type owl:NamedIndividual ,
                       :Release ;
              <http://purl.org/ontology/mo/releaseType> <http://purl.org/ontology/mo/album> ;
              :releasedBy :IronMaiden ;
              :releaseTitle "Dance Of Death" ;
              :releaseYear "2003"^^xsd:gYear .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/ElekctraRecords
:ElekctraRecords rdf:type owl:NamedIndividual ,
                          :Label ;
                 :hasCountry :USA ;
                 :producer :Metallica ;
                 :labelID 3 ;
                 :labelName "Elektra Records" ;
                 :labelStatus "Active" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/HeavyMetal
:HeavyMetal rdf:type owl:NamedIndividual ,
                     :MetalGenre .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/IronMaiden
:IronMaiden rdf:type owl:NamedIndividual ,
                     :Band ;
            :hasCountry :UK ;
            :producedBy :ColumbiaRecords ;
            :releases :DanceOfDeath ;
            :bandID 3 ;
            :bandName "Iron Maiden" ;
            :bandStatus "Active" ;
            rdfs:comment "Iron Maiden music group" ;
            rdfs:label "IronMaiden" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/MasterOfPuppets
:MasterOfPuppets rdf:type owl:NamedIndividual ,
                          :Release ;
                 <http://purl.org/ontology/mo/releaseType> <http://purl.org/ontology/mo/album> ;
                 :releasedBy :Metallica ;
                 :releaseTitle "Master Of Puppets" ;
                 :releaseYear "1986"^^xsd:gYear .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Megadeth
:Megadeth rdf:type owl:NamedIndividual ,
                   :Band ;
          :hasCountry :USA ;
          :hasGenre :HeavyMetal ,
                    :ThrashMetal ;
          :producedBy :CapitolRecords ;
          :releases :RustInPeace ;
          :bandID 2 ;
          :bandName "Megadeth" ;
          :bandStatus "Active" ;
          <http://purl.org/dc/terms/bibliographicCitation> "Megadeth. Encyclopaedia Metallum: The Metal Archives. Accessed 2026. https://www.metal-archives.com/bands/megadeth/138" ;
          rdfs:comment "Megadeth music group" ;
          rdfs:label "Megadeth" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Metallica
:Metallica rdf:type owl:NamedIndividual ,
                    :Band ;
           :hasCountry :USA ;
           :hasGenre :HeavyMetal ,
                     :ThrashMetal ;
           :producedBy :ElekctraRecords ;
           :releases :MasterOfPuppets ;
           :bandID 1 ;
           :bandName "Metallica" ;
           :bandStatus "Active" ;
           rdfs:comment "Metallica music group" ;
           rdfs:label "Metallica" .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/RustInPeace
:RustInPeace rdf:type owl:NamedIndividual ,
                      :Release ;
             <http://purl.org/ontology/mo/releaseType> <http://purl.org/ontology/mo/album> ;
             :releasedBy :Megadeth ;
             :releaseTitle "Rust In Peace" ;
             :releaseYear "1990"^^xsd:gYear .


###  http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Slayer
:Slayer rdf:type owl:NamedIndividual ,
