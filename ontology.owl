<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal#"
     xml:base="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:mo="http://purl.org/ontology/mo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:ontometal="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal">
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal-0.0.1_dev"/>
        <owl:imports rdf:resource="http://purl.org/ontology/mo/"/>
        <dc:contributor>Ocean Berlinghieri García</dc:contributor>
        <dc:created>2026-04-19</dc:created>
        <dc:creator>Ocean Berlinghieri García</dc:creator>
        <dc:publisher>Ocean Berlinghieri García</dc:publisher>
        <dc:title>ontometal</dc:title>
        <terms:license>https://creativecommons.org/licenses/by-nc-nd/3.0/es/legalcode.es</terms:license>
        <vann:preferredNamespacePrefix>om</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal</vann:preferredNamespaceUri>
        <rdfs:comment>Ontology about metal music</rdfs:comment>
        <owl:versionInfo>0.0.1_dev - First ontology prototype</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/contributor"/>
    


    <!-- http://purl.org/dc/elements/1.1/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/created"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/publisher"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/bibliographicCitation -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/NET/c4dm/event.owl#agent -->


    <owl:ObjectProperty rdf:about="http://purl.org/NET/c4dm/event.owl#agent"/>
    


    <!-- http://purl.org/NET/c4dm/event.owl#isAgentIn -->


    <owl:ObjectProperty rdf:about="http://purl.org/NET/c4dm/event.owl#isAgentIn"/>
    


    <!-- http://purl.org/ontology/ao/core#genre -->


    <owl:ObjectProperty rdf:about="http://purl.org/ontology/ao/core#genre"/>
    


    <!-- http://purl.org/ontology/mo/releaseType -->


    <owl:ObjectProperty rdf:about="http://purl.org/ontology/mo/releaseType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Release"/>
        <rdfs:range rdf:resource="http://purl.org/ontology/mo/ReleaseType"/>
        <rdfs:comment xml:lang="en">Defines de type of a release as album, single, compilation..</rdfs:comment>
        <rdfs:label xml:lang="en">releaseType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasCountry -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasCountry">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/based_near"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Country"/>
        <rdfs:comment xml:lang="en">Relates an entity with its origin country</rdfs:comment>
        <rdfs:label xml:lang="en">hasCountry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasGenre -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasGenre">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/ontology/ao/core#genre"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre"/>
        <rdfs:comment xml:lang="en">Relates a band with one or more genres</rdfs:comment>
        <rdfs:label xml:lang="en">hasGenre</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasSpecialization -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/hasSpecialization">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/ontology/ao/core#genre"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre"/>
        <rdfs:label xml:lang="en">Relates a label with its preferred musical genre</rdfs:label>
        <rdfs:label xml:lang="en">hasSpecialization</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producedBy">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/NET/c4dm/event.owl#isAgentIn"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:comment xml:lang="en">Relates a band which is produces by a label</rdfs:comment>
        <rdfs:label>producedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/producer">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/NET/c4dm/event.owl#agent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:comment xml:lang="en">Relates a band or musical composition to its producer (label)</rdfs:comment>
        <rdfs:label xml:lang="en">producer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releasedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releasedBy">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/made"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releases"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Release"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:comment xml:lang="en">Relates a release with the band that released it</rdfs:comment>
        <rdfs:label xml:lang="en">releasedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releases -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releases">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/maker"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Release"/>
        <rdfs:comment xml:lang="en">Relates a band with a release</rdfs:comment>
        <rdfs:label xml:lang="en">releases</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://xmlns.com/foaf/0.1/based_near -->


    <owl:ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/based_near"/>
    


    <!-- http://xmlns.com/foaf/0.1/made -->


    <owl:ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/made"/>
    


    <!-- http://xmlns.com/foaf/0.1/maker -->


    <owl:ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/maker"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/available -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/available">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/date"/>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/dc/terms/date -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/date"/>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandID -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandID">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <rdfs:comment xml:lang="en">Identifier by metal archives</rdfs:comment>
        <rdfs:label xml:lang="en">bandID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandName">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/name"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of a given band</rdfs:comment>
        <rdfs:label xml:lang="en">bandName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandStatus -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/bandStatus">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/status"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/countryName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/countryName">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/name"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Country"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of a given country</rdfs:comment>
        <rdfs:label xml:lang="en">countryName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelID -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelID">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <rdfs:comment xml:lang="en">Identifier by metal archives</rdfs:comment>
        <rdfs:label xml:lang="en">labelID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelName">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/name"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of a given label</rdfs:comment>
        <rdfs:label xml:lang="en">labelName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelStatus -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelStatus">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/status"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelWebsiteURL -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/labelWebsiteURL">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/url"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">URL of a label website</rdfs:comment>
        <rdfs:label xml:lang="en">labelWebsiteURL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/metalArchivesURL -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/metalArchivesURL">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/url"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">URL of a band page in metal archives website</rdfs:comment>
        <rdfs:label xml:lang="en">metalArchivesURL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releaseTitle -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releaseTitle">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/title"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Release"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Title of a band release</rdfs:comment>
        <rdfs:label xml:lang="en">releaseTitle</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releaseYear -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/releaseYear">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/date"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Release"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:comment xml:lang="en">Year when a band release came out</rdfs:comment>
        <rdfs:label xml:lang="en">releaseYear</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/url -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/url">
        <rdfs:comment>A link to acess a website</rdfs:comment>
        <rdfs:label>url</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- http://xmlns.com/foaf/0.1/status -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/status"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/ontology/mo/Genre -->


    <owl:Class rdf:about="http://purl.org/ontology/mo/Genre">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre"/>
    </owl:Class>
    


    <!-- http://purl.org/ontology/mo/Label -->


    <owl:Class rdf:about="http://purl.org/ontology/mo/Label">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label"/>
    </owl:Class>
    


    <!-- http://purl.org/ontology/mo/MusicGroup -->


    <owl:Class rdf:about="http://purl.org/ontology/mo/MusicGroup">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band"/>
    </owl:Class>
    


    <!-- http://purl.org/ontology/mo/ReleaseType -->


    <owl:Class rdf:about="http://purl.org/ontology/mo/ReleaseType"/>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band -->


    <owl:Class rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Band">
        <rdfs:comment xml:lang="en">Class representing a music group. Equivalent to mo:MusicGroup</rdfs:comment>
        <rdfs:label xml:lang="en">Band</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Country -->


    <owl:Class rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Country">
        <rdfs:comment xml:lang="en">A class representing a country</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre -->


    <owl:Class rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre">
        <rdfs:comment xml:lang="en">Music genre class, equivalent to mo:Genre</rdfs:comment>
        <rdfs:label xml:lang="en">Genre</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label -->


    <owl:Class rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Label">
        <rdfs:comment xml:lang="en">Comercial organization from music industry. Equivalent to mo:Label</rdfs:comment>
        <rdfs:label xml:lang="en">Label</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/MetalGenre -->


    <owl:Class rdf:about="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/MetalGenre">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ocean/ontologies/2026/3/ontometal/Genre"/>
        <rdfs:comment xml:lang="en">A class representing musical subgenres from metal music</rdfs:comment>
        <rdfs:label xml:lang="en">MetalGenre</rdfs:label>
